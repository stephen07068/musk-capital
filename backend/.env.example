FLASK_ENV=development
FLASK_DEBUG=1
DATABASE_URL=sqlite:///muskcapital.db

# JWT settings
JWT_SECRET_KEY=change-this-in-production-to-a-long-random-string
JWT_ACCESS_HOURS=24
JWT_REFRESH_DAYS=30

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate Limiting
RATELIMIT_DEFAULT=200 per day;50 per hour

# Email configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@muskcapital.com

# Deposit Wallets (change for production)
WALLET_BTC=bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh
WALLET_ETH=0x71C7656EC7ab88b098defB751B7401B5f6d8976F
